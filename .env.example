# ─── Database ──────────────────────────────────────────────
DB_PASSWORD=changeme
DB_HOST_PORT=5433
DATABASE_URL=postgresql://storm:changeme@localhost:5433/storm

# ─── Polymarket Wallet ────────────────────────────────────
PRIVATE_KEY=0xYourPolygonPrivateKey
DEPOSIT_WALLET_ADDRESS=0xYourProxyOrDepositWallet

# ─── Polymarket L2 API Credentials ────────────────────────
# (ใช้ `python -m scheduler.executor` เพื่อ derive ครั้งแรก)
POLY_API_KEY=
POLY_SECRET=
POLY_PASSPHRASE=

# Keep true for scheduler smoke tests. Set false only when ready to place orders.
POLY_DRY_RUN=true

# Buy gates
MAX_YES_PRICE=0.65
MIN_BOUNDARY_MARGIN=0.20

# Set 0 to disable periodic idle heartbeat logs.
SCHEDULER_HEARTBEAT_SECONDS=60

# Run one normal cycle immediately when `python -m scheduler` starts.
SCHEDULER_RUN_ON_START=true
