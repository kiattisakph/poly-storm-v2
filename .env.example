# ─── Database ──────────────────────────────────────────────
DB_PASSWORD=changeme
DB_HOST_PORT=5433
DATABASE_URL=postgresql://storm:changeme@localhost:5433/storm

# ─── Polymarket Wallet ────────────────────────────────────
PRIVATE_KEY=0xYourPolygonPrivateKey
DEPOSIT_WALLET_ADDRESS=0xYourProxyOrDepositWallet
# 0=EOA (self-custody, no proxy), 1=POLY_PROXY (browser wallet / deposit proxy),
# 2=POLY_GNOSIS_SAFE (multisig), 3=POLY_1271 (advanced EIP-1271, signer=funder)
# Most Polymarket users with a deposit/proxy wallet should use 1.
POLY_SIGNATURE_TYPE=1

# ─── Polymarket L2 API Credentials ────────────────────────
# (ใช้ `python -m scheduler.executor` เพื่อ derive ครั้งแรก)
POLY_API_KEY=
POLY_SECRET=
POLY_PASSPHRASE=

# Keep true for scheduler smoke tests. Set false only when ready to place orders.
POLY_DRY_RUN=true

# Buy gates
MAX_YES_PRICE=0.65
MIN_BOUNDARY_MARGIN=0.20

# Market target date uses D+1 from this timezone.
# Example: 2026-05-12 23:05 Asia/Bangkok targets the May 13 market.
MARKET_TARGET_TIMEZONE=Asia/Bangkok

# Telegram notifications. Keep disabled unless token/chat id are configured.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Set 0 to disable periodic idle heartbeat logs.
SCHEDULER_HEARTBEAT_SECONDS=60

# Run one normal cycle immediately when `python -m scheduler` starts.
SCHEDULER_RUN_ON_START=true
